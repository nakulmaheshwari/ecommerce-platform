{
	"info": {
		"_postman_id": "74c31b47-0ef6-43df-8178-ee2c2be94e27",
		"name": "Cart Service API (360-Degree Testing)",
		"description": "Comprehensive Postman collection for the E-commerce Cart Service. Includes all endpoints, logical test cases, and error handling verification. Requires `baseUrl` and `jwtToken` variables.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Base Operations",
			"item": [
				{
					"name": "Get Current User Cart",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart"
							]
						},
						"description": "Retrieves the cart for the currently authenticated user. All item details are snapshots from the Product Catalog."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is a valid Cart object\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('userId');",
									"    pm.expect(jsonData).to.have.property('items');",
									"    pm.expect(jsonData.items).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Subtotal consistency\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.subtotalRupees).to.eql(jsonData.subtotalPaise / 100);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Clear Cart",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart"
							]
						},
						"description": "Removes all items from the current user's cart in Redis."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 204\", function () {",
									"    pm.response.to.have.status(204);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "Item Management",
			"item": [
				{
					"name": "Add Item to Cart",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"skuId\": \"APP-IPH15-128-NAT\",\n    \"quantity\": 1\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart/items",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart",
								"items"
							]
						},
						"description": "Adds a new SKU to the cart. If the SKU already exists, it increments the quantity."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Added item is present in response\", function () {",
									"    var jsonData = pm.response.json();",
									"    var reqBody = JSON.parse(pm.request.body.raw);",
									"    var item = jsonData.items.find(i => i.skuId === reqBody.skuId);",
									"    pm.expect(item).to.not.be.undefined;",
									"    pm.expect(item.quantity).to.be.at.least(reqBody.quantity);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Update Item Quantity",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"quantity\": 5\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart/items/APP-IPH15-128-NAT",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart",
								"items",
								"APP-IPH15-128-NAT"
							]
						},
						"description": "Sets the precise quantity for an existing cart item."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Quantity updated correctly\", function () {",
									"    var jsonData = pm.response.json();",
									"    var reqBody = JSON.parse(pm.request.body.raw);",
									"    var item = jsonData.items.find(i => i.skuId === 'APP-IPH15-128-NAT');",
									"    pm.expect(item.quantity).to.eql(reqBody.quantity);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Remove Item from Cart",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart/items/APP-IPH15-128-NAT",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart",
								"items",
								"APP-IPH15-128-NAT"
							]
						},
						"description": "Removes a specific SKU from the user's cart."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Item is removed from response\", function () {",
									"    var jsonData = pm.response.json();",
									"    var item = jsonData.items.find(i => i.skuId === 'APP-IPH15-128-NAT');",
									"    pm.expect(item).to.be.undefined;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "Negative Scenarios (Error Testing)",
			"item": [
				{
					"name": "Unauthorized Access",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart"
							]
						},
						"description": "Verifies that requests without a JWT are rejected."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 401\", function () {",
									"    pm.response.to.have.status(401);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Add Item - Invalid SKU",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"skuId\": \"\",\n    \"quantity\": 1\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart/items",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart",
								"items"
							]
						},
						"description": "Verifies that empty SKU IDs are rejected by @Valid annotation."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 400\", function () {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Add Item - Invalid Quantity",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"skuId\": \"APP-IPH15-128-NAT\",\n    \"quantity\": 0\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/cart/items",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"cart",
								"items"
							]
						},
						"description": "Verifies that quantities less than 1 are rejected."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 400\", function () {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		}
	],
